rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 使用者資料：僅後端 Admin SDK 可存取（無 client 端規則）
    match /users/{userId} {
      allow read, write: if false;
    }

    // 稽核日誌：僅後端 Admin SDK 可寫入
    match /audit_logs/{logId} {
      allow read, write: if false;
    }

    // 系統 metadata：登入使用者可讀，僅後端可寫
    match /system/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 業務資料集合：登入使用者可讀寫
    match /members/{docId} {
      allow read, write: if request.auth != null;
    }
    match /cases/{docId} {
      allow read, write: if request.auth != null;
    }
    match /opinions/{docId} {
      allow read, write: if request.auth != null;
    }
    match /services/{docId} {
      allow read, write: if request.auth != null;
    }
    match /billings/{docId} {
      allow read, write: if request.auth != null;
    }

    // 其他所有集合：拒絕存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
